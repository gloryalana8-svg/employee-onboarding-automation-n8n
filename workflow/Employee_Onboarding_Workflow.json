parameters	
jsCode	'const employee = $input.first().json;\n\nconst fullName = `${employee["First Name "]} ${employee["Last Name "]}`;\n\n// Create onboarding tasks\nconst tasks = [\n  {\n    EmployeeID: employee.EmployeeID,\n    EmployeeName: fullName,\n    Department: employee.Department,\n    Task: "Create company email account",\n    AssignedTo: "IT Department",\n    Status: "Pending"\n  },\n  {\n    EmployeeID: employee.EmployeeID,\n    EmployeeName: fullName,\n    Department: employee.Department,\n    Task: "Prepare workstation and laptop",\n    AssignedTo: "IT Department",\n    Status: "Pending"\n  },\n  {\n    EmployeeID: employee.EmployeeID,\n    EmployeeName: fullName,\n    Department: employee.Department,\n    Task: "Prepare employee ID card",\n    AssignedTo: "HR Department",\n    Status: "Pending"\n  },\n  {\n    EmployeeID: employee.EmployeeID,\n    EmployeeName: fullName,\n    Department: employee.Department,\n    Task: "Assign department manager",\n    AssignedTo: employee["Manager Email"],\n    Status: "Pending"\n  },\n  {\n    EmployeeID: employee.EmployeeID,\n    EmployeeName: fullName,\n    Department: employee.Department,\n    Task: "Schedule orientation session",\n    AssignedTo: "HR Department",\n    Status: "Pending"\n  },\n  {\n    EmployeeID: employee.EmployeeID,\n    EmployeeName: fullName,\n    Department: employee.Department,\n    Task: "Enroll employee in payroll system",\n    AssignedTo: "Finance Department",\n    Status: "Pending"\n  }\n];\n\n// Return each task as a separate item\nreturn tasks.map(task => ({\n  json: task\n}));'
